# NanoClaw GWS-EA Configuration
# Copy this to .env and fill in your values.

# --- Required: Anthropic API Key (may also be able to use Claude Code OAuth Token)---
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# --- Required: EA Identity ---
# Principal's name (used for sender labels, name-variant matching)
PRINCIPAL_NAME=
# Principal's email addresses (comma-separated, all addresses that belong to them)
PRINCIPAL_EMAILS=
# EA's email address (the Workspace account the EA operates as)
ASSISTANT_EMAIL=
# EA's display name (used for triggers, email from_name)
ASSISTANT_NAME=

# --- Required: Google OAuth (from GCP Console) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Optional: Polling intervals (ms) ---
# EMAIL_POLL_INTERVAL=60000
# GCHAT_POLL_INTERVAL=30000

# --- Optional: Heartbeat ---
# Google Chat space ID for proactive sweep logs (e.g., LEPQYwgZ9QL)
# HEARTBEAT_SPACE_ID=

# --- Optional: Timezone ---
# TZ=America/Los_Angeles
