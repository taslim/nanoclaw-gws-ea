# NanoClaw GWS-EA — non-secret config
# Secrets (Anthropic, Workspace SA) live in OneCLI vault / on disk, not here.
# Copy this to .env and fill in your values.

# --- OneCLI (credential gateway) ---
ONECLI_URL=http://127.0.0.1:10254

# --- Principal & EA Identity ---
# Principal's first name (used for sender labels, name-variant matching).
PRINCIPAL_NAME=
# Principal's last name (optional — used in the EA's persona signoff and
# identity declarations; leave blank for mononymous principals).
PRINCIPAL_LAST_NAME=
# Principal's email addresses (comma-separated). The first address is
# treated as primary for default event creation in the scheduling skill.
PRINCIPAL_EMAILS=
# EA's first name (used for triggers, email from_name).
# Also used as the prefix for OneCLI vault secrets and agent display names
# (`<lowercased>-<purpose>`). Treat as install-stable — changing post-install
# requires a coordinated rename.
ASSISTANT_NAME=
# EA's last name (optional — used in the persona signoff;
# leave blank for mononymous assistants).
ASSISTANT_LAST_NAME=
# EA's email address (the Workspace account the EA operates as)
ASSISTANT_EMAIL=

# GChat Pub/Sub topic for the EA's Workspace Events subscription
GCHAT_PUBSUB_TOPIC=

# Google Chat space ID for proactive sweep logs
HEARTBEAT_SPACE_ID=

# --- Optional: Polling intervals (ms) ---
# EMAIL_POLL_INTERVAL=60000

# --- Optional: Voice-note transcription (local whisper.cpp) ---
# Path to the whisper-cli binary (must be on PATH or absolute).
# WHISPER_BIN=whisper-cli
# Path to a ggml whisper model. If the file is missing, transcription is
# silently skipped and audio attachments fall through to the no-transcript
# rendering. Install whisper.cpp + a model to enable.
# WHISPER_MODEL=data/models/ggml-base.bin

# --- Optional: Timezone ---
# TZ=America/Los_Angeles