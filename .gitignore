# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - per-installation state, not tracked
groups/*

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed.
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

# Per-subagent memory (local, not tracked)
.claude/agent-memory/

agents-sdk-docs

# Fork-specific tracked files — per-group persona deltas and heartbeat sweep procedure.
# These override the broad `groups/*` and `**/CLAUDE.local.md` rules above.

# main group
!groups/main/
groups/main/*
!groups/main/heartbeats/
!groups/main/CLAUDE.local.md

# email-external group
!groups/email-external/
groups/email-external/*
!groups/email-external/CLAUDE.local.md

# Templated persona files — sources live in templates/, rendered at setup
# time with values from .env. Never commit the rendered output to the public
# fork; users' rendered content is local-only.
container/CLAUDE.md
container/skills/email-triage/SKILL.md
container/skills/scheduling/SKILL.md
