# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - track EA structure, ignore runtime data
groups/*
!groups/main/
!groups/global/
!groups/email-principal/
!groups/email-external/
!groups/heartbeat/

# Within tracked groups: track docs, ignore runtime
groups/main/*
!groups/main/CLAUDE.md
!groups/main/procedures/
groups/global/*
!groups/global/CLAUDE.md
!groups/global/profile.md
!groups/global/procedures/
groups/email-principal/*
!groups/email-principal/CLAUDE.md
groups/email-external/*
!groups/email-external/CLAUDE.md
groups/heartbeat/*
!groups/heartbeat/CLAUDE.md

# Runtime data (never tracked, even in whitelisted groups)
groups/*/conversations/
groups/*/memory/
groups/*/MEMORY.md
groups/*/heartbeat-logs.md
groups/*/auth/

# Secrets
*.keys.json
.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Claude Code agent memory
.claude/agent-memory/

# Maintainer-only skills (not for gws-ea)
.claude/skills/sync-gws-ea/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
